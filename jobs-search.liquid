{% page_required_header %}

{% comment %}set is_referral_site variable{% endcomment %}
{% capture is_referral_site %}false{% endcapture %}

{% comment %}for similar jobs in Job Details page only {% endcomment %}
{% if params['ns_similar_jobs'] == '1' %}
    <div class="similar-jobs--jobs-search-js">
        {% for similar_job in jobs %}
            {% if params['ns_job_id'] == similar_job.id %}
                {% capture is_same_job %}true{% endcapture %}

            {% else %}
                {% if is_same_job != 'true' and forloop.index == 4 %}
                    <!--do nothing-->
                {% else %}
                    <div class="job-details__similar-jobs-item">
                        <h3 class="heading-5 space-none">{{ similar_job | link_to_job }}</h3>
                        <p>
                            {% if similar_job.location.city != blank %}
                                {{ similar_job.location.city }}{% if similar_job.location.state_prov_short != blank %},{% endif %}
                            {% endif %}
                            {% if similar_job.location.state_prov_short != blank %}
                                {% capture job_location_state_prov_short_no_digit %}{{ similar_job.location.state_prov_short | replace_global_regex: "[\d]", ":::" }}{% endcapture %}
                                {% if job_location_state_prov_short_no_digit contains ':::' %}
                                    {{ similar_job.location.state_prov }}
                                {% else %}
                                    {{ similar_job.location.state_prov_short }}
                                {% endif %}
                            {% endif %}
                            {% if similar_job.cfml3 != blank %}
                                <br />
                                {{ similar_job.cfml3 }}
                            {% endif %}
                        </p>
                    </div>
                {% endif %}
            {% endif %}
        {% endfor %}
    </div>

{% comment %}if not for similar jobs{% endcomment %}
{% else %}
    {% comment %}Check if Saved Jobs are not all archived jobs{% endcomment %}
    {% if params['saved_jobs'] == '1' and jobs.total_entries == 0 %}
        <script type="text/javascript">
            var c_jobs_temp = localStorage.getItem('c_jobs') ? JSON.parse(localStorage.getItem('c_jobs')) : [];
            var current_saved_jobs_url = '{{ request_fullpath }}';
            var saved_jobs_query = '/jobs/search?external_id[]='+c_jobs_temp.join('&external_id[]=')+'&saved_jobs=1';

            if (saved_jobs_query == current_saved_jobs_url) {
                localStorage.removeItem('c_jobs');
                setTimeout(function() {
                    {% redirect_permanent '/pages/saved-jobs' %}
                }, 2000);
            }
        </script>
    {% endif %}

    {% capture jobs_category_content_tag %}{{ params['ns_category'] }}-jobs-content{% endcapture %}
    {{ jobs_category_content_tag | pages_with_tag | assign_to: 'jobs_category_content' }}

    <div class="page-details-wrapper">
        <div class="space-xlarge">

            <div class="jobs-category-section">
                <div class="hide">
                    {{ notificationlabel | candidate_job_notification_link }}
                </div>
                <div class="row">
                    <div class="columns">
                        {% if params['saved_jobs'] == '1' %}
                            <h1>Saved Jobs</h1>

                        {% elsif jobs_category_content.size > 0 %}
                            <h1>{{ jobs_category_content[0].title }}</h1>
                            {{ jobs_category_content[0].content | replace_first: '<p>','<p class="hide">' }}

                            {% capture page_permalink %}{{ jobs_category_content[0].permalink }}{% endcapture %}
                            {% include '/pilgrims__config__page-section-logic' %}

                        {% elsif params['q'] != blank or params['ns_location'] != blank or params['location'] != blank %}   
                            <h1>
                                {{ jobs.total_entries }}
                                {% if params['q'] != blank %}
                                    {{ params['q'] | escape_html }} jobs
                                {% endif %}

                                {% if params['ns_location'] != blank and params['q'] != blank %}
                                    in
                                {% endif %}

                                {% if params['location'] != blank and params['q'] != blank %}
                                    in
                                {% endif %}

                                {% if params['ns_location'] != blank %}
                                    {{ params['ns_location'] }}
                                {% endif %}

                                {% if params['location'] != blank %}
                                    {{ params['location'] }}
                                {% endif %}

                                {% if params['q'] == blank %}
                                    jobs
                                {% endif %}

                                found

                            </h1>
                        {% else %}
                            <h1>Job Search Results</h1>
                            {% if params['ns_inactive_job'] == '1' %}
                                <p>This job posting you were looking for is no longer active. Please search for other jobs instead.</p>
                            {% endif %}

                        {% endif %}
                    </div>
                </div>
            </div><!--close .jobs-category-section-->

            {% if jobs.total_entries > 0 %}
            <div class="jobs-heading">
                <div class="row">
                    <div class="columns">
                        <div class="text-small space-medium">
                            {% if params['page'] == blank or params['page'] == 1 %}
                                Showing 1-{{ jobs.length }} of {{ jobs.total_entries }} result{% if jobs.total_entries > 1 %}s{% endif %}
                            {% else %}
                                {% if params['per_page'] == blank %}
                                    {% capture tal_per_page %}25{% endcapture %}
                                {% else %}
                                    {% capture tal_per_page %}{{ params['per_page'] }}{% endcapture %}
                                {% endif %}
                                {% capture tal_jobs_length %}{{ tal_per_page | minus: jobs.length }}{% endcapture %}
                                Showing {{ params['page'] | minus: 1 | times: tal_per_page | plus: 1 }}-{{ tal_per_page | times: params['page'] | minus: tal_jobs_length }} of {{ jobs.total_entries }} result{% if jobs.total_entries > 1 %}s{% endif %}
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div><!--close .jobs-heading-->
            {% endif %}

            <div class="row">
                {% if jobs.total_entries > 0 and params['saved_jobs'] != '1' %}
                    <div class="columns medium-4 large-3">
                        <div class="facet-section">
                            <section>
                                {% capture has_multiple_facet_options %}false{% endcapture %}
                                <div class="facet-section__heading hide">
                                    <a href="javascript:void(0);" class="facet-filter-results-button branded-button branded-button-1 full-width hide-for-medium" rel="nofollow">Filter Your Results</a>
                                    <h2 class="heading-5 show-for-medium">Filter Your Results <span class="facet-section__clear-all text-small"><a href="{{ "cfm1_seo,cfm2_seo,cfm3_seo,cfm4_seo,cfm5_seo,cfm6_seo,cfm7_seo,cfm8_seo,cfm9_seo,job_tags_seo,location_country_seo,location_state_seo,location_city_seo" | get_facet_url_sans }}" rel="nofollow" class="facet-item__option-link js show-for-medium">Clear All</a></span></h2>
                                </div>

                                <div class="facet-section-inner">
                                    <!-- Assigning the Facets -->
                                    {% assign facet_setup = "Category, cfm4_seo, multi, asc, 10, 100, collapsed;
                                    Country, location_country_seo, single, asc, 10, 100, collapsed;
                                    State, location_state_seo, single, asc, 10, 100, collapsed;
                                    City, location_city_seo, multi, asc, 10, 100, collapsed;" | split: ';' | assign_to: 'facet_setup_split' %}

                                    {% for facet_attrs in facet_setup_split %}
                                        <!-- Setting variables for the Facet attributes -->
                                        {{ facet_attrs | split: ', ' | assign_to: 'facet_attr' }}
                                        {% assign facet_heading = facet_attr[0] %}
                                        {% assign facet_field = facet_attr[1] %}
                                        {% assign facet_type = facet_attr[2] %}
                                        {% assign facet_order = facet_attr[3] %}
                                        {% assign facet_num_display = facet_attr[4] %}
                                        {% assign facet_num_limit = facet_attr[5] %}
                                        {% assign facet_expanded = facet_attr[6] %}

                                        {% capture facet_num_display_int %}{{ facet_num_display }}{% endcapture %}
                                        {% assign facet_num_display_int = facet_num_display_int | times: 1 %}

                                        <!-- Setting the Facets -->
                                        {% if facet_type == "multi" %}
                                            {{ facet_field | facet_multi: facet_num_limit, facet_order | assign_to: 'fa' }}
                                            {% assign facets = fa %}
                                        {% else %}
                                            {{ facet_field | facet_single: facet_num_limit, facet_order | assign_to: 'fa' }}
                                            {% assign facets = fa %}
                                        {% endif %}

                                        {% assign facet_results = facets[facet_field] %}

                                        {{ facet_field | selected_facets_by_name | assign_to: 'fas' }}
                                        {% assign facet_select = fas %}

                                        {% if facet_results.size > 1 or facet_select.size >= 1 %}
                                            {% if has_multiple_facet_options == 'false' %}
                                                <script>$('.facet-section__heading').removeClass('hide');</script>
                                            {% endif %}
                                            {% capture has_multiple_facet_options %}true{% endcapture %}
                                                
                                            {% if facet_select.size >= 1 %}
                                                <!-- Set variable to store Facet option Clear Filter link -->
                                                {% assign clear_filter = "" %}
                                                {% capture clear_filter %}{{ facet_field | get_facet_url_sans }}{% endcapture %}
                                            {% endif %}

                                            <div class="facet-item padded-v-small {% if facet_select.size < 1 and facet_expanded != 'expanded' %}facet-item--collapsed plus{% else %}facet-item--expanded minus{% endif %}">
                                                <div class="facet-item__heading">
                                                    <button class="heading-6 space-none js" aria-expanded="{% if facet_expanded != 'expanded' %}false{% else %}true{% endif %}">{{ facet_heading }} <span class="facet-item__heading-expand-collapse"></span></button>
                                                </div>
                                                <div class="facet-item__options">
                                                    <div class="space-small"></div>
                                                    {% assign facet_num_limit_counter = "0" %}
                                                    {% for facet in facet_results %}
                                                        {% if facet['permalink'] != "" %}

                                                            {% if facet_num_limit_counter == "0" %}
                                                                <div class="facet-item__row">
                                                            {% endif %}

                                                            {% if facet_num_limit_counter == facet_num_display %}
                                                                </div>

                                                                <div><a class="facet-item__show-more js" ref="{{ facet_field }}" href="javascript: void(0);" rel="nofollow">+ Show more</a></div>

                                                                <div class="facet-item__row facet-item__row--hidden" id="facet-item__row--{{ facet_field }}">
                                                            {% endif %}

                                                            <div class="facet-item__options-item clearfix padded-v-small">
                                                                <a href="{{ facet['query'] }}" class="facet-item__option-link js"{% if facet_select.size >= 1 %} rel="nofollow"{% endif %}>
                                                                    <span class="facet-item__options-item-type facet-item__options-item-type--{{ facet_type }} {% if facet['is_selected'] == true %}facet-item__options-item-type--selected{% endif %}"></span>
                                                                    <span class="facet-item__option-item-label">{{ facet["label"] }}</span>
                                                                    <span class="facet-item__option-item-count">{{ facet["count"] }}<span class="show-for-sr">jobs</span></span>
                                                                    <span class="show-for-sr">{% if facet['is_selected'] == true %}selected{% endif %}</span>
                                                                </a>
                                                            </div>
                                                            {% capture facet_num_limit_counter %}{{ facet_num_limit_counter | plus: '1' }}{% endcapture %}
                                                        {% endif %}

                                                        {% if forloop.last and facet_num_limit_counter != "0" %}
                                                            </div>
                                                        {% endif %}

                                                        <!--Keep select facets after "Show More" open-->
                                                        {% if facet['is_selected'] == true and forloop.index > facet_num_display_int %}
                                                            <script>
                                                                $('.facet-item__show-more.js').addClass('hide');
                                                                $('.facet-item__row--hidden').removeClass('facet-item__row--hidden');
                                                            </script>
                                                        {% endif %}
                                                    {% endfor %}
                                                </div><!--close .facet-item__options-->
                                                {% if facet_select.size >= 1 %}<div><a href="{{ clear_filter }}" class="facet-item__heading-clear text-small" rel="nofollow">Clear Filters</a></div>{% endif %}
                                            </div><!--close .facet-item-->
                                        {% endif %}
                                    {% endfor %}
                                    <a href="{{ "cfm1_seo,cfm2_seo,cfm3_seo,cfm4_seo,cfm5_seo,cfm6_seo,cfm7_seo,cfm8_seo,cfm9_seo,job_tags_seo,location_country_seo,location_state_seo,location_city_seo" | get_facet_url_sans }}" rel="nofollow" class="facet-item__option-link js hide-for-medium">Clear All</a>
                                    <div class="padded-v-medium hide-for-medium"><a href="javascript:void(0);" class="facet-filter-results-button branded-button branded-button-1" rel="nofollow">Close</a></div>
                                </div><!--close .facet-section-inner-->
                            </section>

                            <div class="padded-v-small">
                                <p><a href="javascript:void(0);" class="candidate-notification-link branded-button branded-button-1 full-width" rel="nofollow">Set Up Job Alerts</a></p>
                            </div>

                            {% comment %}check if there are valid frequent job searches{% endcomment %}
                            {% assign frequent_job_search_counter = 0 %}
                            {% capture frequent_job_searches_list %}{% endcapture %}
                            {% for search_data in visitor.frequent_job_searches limit: 100 %}
                                {% if search_data.url contains '?' %}
                                     {% if search_data.url contains 'external_id' or search_data.url contains 'per_page' %}
                                        {% capture valid_frequent_search %}false{% endcapture %}
                                    {% else %}
                                        {% capture valid_frequent_search %}true{% endcapture %}
                                    {% endif %}
                                {% else %}
                                    {% if search_data.url contains '/search/jobs' %}
                                        {% capture valid_frequent_search %}false{% endcapture %}
                                    {% else %}
                                        {% capture valid_frequent_search %}true{% endcapture %}
                                    {% endif %}
                                {% endif %}

                                {% if valid_frequent_search == 'true' %}
                                    {% assign frequent_job_search_counter = frequent_job_search_counter | plus: 1 %}
                                    {% capture frequent_job_searches_list %}{{ frequent_job_searches_list }}<div class="visitor-item"><a href="{{ search_data.url }}" rel="nofollow">{{ search_data.title }}</a></div>{% endcapture %}
                                {% endif %}
                                {% if frequent_job_search_counter >= 2 %}
                                    {% break %}
                                {% endif %}
                            {% endfor %}

                            {% comment %}check if there are valid recent job searches{% endcomment %}
                            {% assign recent_job_search_counter = 0 %}
                            {% capture recent_job_searches_list %}{% endcapture %}
                            {% for search_data in visitor.recent_job_searches limit: 100 %}
                                {% if search_data.url contains '?' %}
                                     {% if search_data.url contains 'external_id' or search_data.url contains 'per_page' %}
                                        {% capture valid_recent_search %}false{% endcapture %}
                                    {% else %}
                                        {% capture valid_recent_search %}true{% endcapture %}
                                    {% endif %}
                                {% else %}
                                    {% if search_data.url contains '/search/jobs' %}
                                        {% capture valid_recent_search %}false{% endcapture %}
                                    {% else %}
                                        {% capture valid_recent_search %}true{% endcapture %}
                                    {% endif %}
                                {% endif %}

                                {% if valid_recent_search == 'true' %}
                                    {% assign recent_job_search_counter = recent_job_search_counter | plus: 1 %}
                                    {% capture recent_job_searches_list %}{{ recent_job_searches_list }}<div class="visitor-item"><a href="{{ search_data.url }}" rel="nofollow">{{ search_data.title }}</a></div>{% endcapture %}
                                {% endif %}
                                {% if recent_job_search_counter >= 2 %}
                                    {% break %}
                                {% endif %}
                            {% endfor %}

                            <section>
                                {% if visitor.frequent_job_searches.total_entries > 0 or visitor.recent_job_searches.total_entries > 0 or visitor.recent_jobs.total_entries > 0 or visitor.recommended_jobs.total_entries > 0 %}
                                    <div class="padded-v-small space-small">
                                        {% if visitor.frequent_job_searches.total_entries > 0 and frequent_job_searches_list != blank %}
                                            <div class="visitor-item-wrapper space-medium">
                                                <h3 class="heading-6">Frequent Job Searches</h3>
                                                {{ frequent_job_searches_list }}
                                            </div><!--close .visitor-item-wrapper-->
                                        {% endif %}

                                        {% if visitor.recent_job_searches.total_entries > 0 and recent_job_searches_list != blank %}
                                            <div class="visitor-item-wrapper space-medium">
                                                <h3 class="heading-6">Recent Job Searches</h3>
                                                {{ recent_job_searches_list }}
                                            </div><!--close .visitor-item-wrapper-->
                                        {% endif %}

                                        {% if visitor.recent_jobs.total_entries > 0 %}
                                            <div class="visitor-item-wrapper space-medium">
                                                <h3 class="heading-6">Recently Viewed Jobs</h3>
                                                {% for job_data in visitor.recent_jobs limit: 2 %}
                                                    <div class="visitor-item"><a href="{{job_data.url}}" rel="nofollow">{{ job_data.title }} - <span>{{ job_data.time_ago }}</span></a></div>
                                                {% endfor %}
                                            </div><!--close .visitor-item-wrapper-->
                                        {% endif %}

                                        {% if visitor.recommended_jobs.total_entries > 0 %}
                                            <div class="visitor-item-wrapper space-medium">
                                                <h3 class="heading-6">Recommended Jobs</h3>
                                                {% for job_data in visitor.recommended_jobs limit: 2 %}
                                                    <div class="visitor-item">{{ job_data | link_to_job }}</div>
                                                {% endfor %}
                                            </div><!--close .visitor-item-wrapper-->
                                        {% endif %}
                                    </div><!--close .branded-box-->
                                {% else %}
                                    {% comment %}
                                    <div class="space-small"><span class="branded-button-outer branded-button-1-outer branded-button-wide-outer">{{ "Personalize your experience" | link_to_social_login }}</span></div>
                                    <!-- <span class="text-small"><a href="{{career_site.enable_tracking_url}}" rel="nofollow">Click here to enable personalized experience</a></span> -->
                                    {% endcomment %}
                                {% endif %}
                            </section>
                        </div><!--close .facet-section-->
                    </div>
                {% endif %}

                <div class="columns{% if jobs.total_entries > 0 and params['saved_jobs'] != '1' %} medium-8 large-9{% endif %}">
                    <section>
                        <div class="jobs-section">
                            <div class="preloader preloader--search">
                                <div class="facet-jobs-loading hide--- hide-for-print" role="alert" aria-labelledby="facet-jobs-loading">
                                    <div class="show-for-sr"><label id="facet-jobs-loading">Loading jobs</label></div>
                                </div>
                            </div>
                            <div class="jobs-section__inner">
                                {% if no_results_found %}
                                    <p>No jobs found matching your search. Please try again or <a href="javascript:void(0);" class="candidate-notification-link" rel="nofollow">set up a job alert</a>.</p>
                                {% else %}
                                    <script>var current_year = new Date().getFullYear();</script>
                                    <div class="jobs-section__list space-medium">
                                        <div class="branded-search space-small hide-for-large">
                                            <select class="sortby-mobile">
                                                <option>Sort{% if params['sort_by'] != blank %}ed{% endif %} by {{ params['sort_by'] | replace: 'default','Relevance' | replace: 'title','Job Title' | replace: 'location_city','Location' | replace: 'cfm4','Category' }}</option>
                                                <option value="default">Relevance</option>
                                                <option value="title">Job Title</option>
                                                <option value="location_city">Location</option>
                                                <option value="cfm4">Category</option>
                                            </select>
                                        </div>

                                        <div class="facet-jobs-loaded hide--- hide-for-print" role="alert" aria-labelledby="facet-jobs-loaded">
                                            <div class="show-for-sr">
                                                <label id="facet-jobs-loaded">
                                                    {% if jobs.total_entries > 0 %}
                                                        {% if params['page'] == blank or params['page'] == 1 %}
                                                            Showing 1-{{ jobs.length }} of {{ jobs.total_entries }} result{% if jobs.total_entries > 1 %}s{% endif %}
                                                        {% else %}
                                                            {% if params['per_page'] == blank %}
                                                                {% capture tal_per_page %}25{% endcapture %}
                                                            {% else %}
                                                                {% capture tal_per_page %}{{ params['per_page'] }}{% endcapture %}
                                                            {% endif %}
                                                            {% capture tal_jobs_length %}{{ tal_per_page | minus: jobs.length }}{% endcapture %}
                                                            Showing {{ params['page'] | minus: 1 | times: tal_per_page | plus: 1 }}-{{ tal_per_page | times: params['page'] | minus: tal_jobs_length }} of {{ jobs.total_entries }} result{% if jobs.total_entries > 1 %}s{% endif %}
                                                        {% endif %}
                                                    {% endif %}
                                                </label>
                                            </div>
                                        </div><!--close .facet-loaded-jobs-->
                                        
                                        <div class="jobs-section__heading padded-v-small show-for-large">
                                            <div class="row">
                                                <div class="columns {% if is_referral_site == 'true' %}large-4{% else %}large-6{% endif %}">
                                                    <h3 class="heading-6"><a class="sort-button" href="javascript:sortjobs('title');" rel="nofollow">Job Title &nbsp;<i class="fa fa-sort text-small" aria-hidden="true" rel="nofollow"></i></a></h3>
                                                </div>
                                                <div class="columns large-3">
                                                    <h3 class="heading-6"><a class="sort-button" href="javascript:sortjobs('location_city');" rel="nofollow">Location &nbsp;<i class="fa fa-sort text-small" aria-hidden="true"></i></a></h3>
                                                </div>
                                                <div class="columns large-3">
                                                    <h3 class="heading-6"><a class="sort-button" href="javascript:sortjobs('cfm4');" rel="nofollow">Category &nbsp;<i class="fa fa-sort text-small" aria-hidden="true"></i></a></h3>
                                                </div>
                                                {% if is_referral_site == 'true' %}
                                                    <div class="columns large-2">
                                                        <h3 class="heading-6">Incentive</h3>
                                                    </div>
                                                {% endif %}
                                            </div>
                                        </div>
                                        <script>
                                            // Sort by functionality
                                            $('.sortby-mobile').change(function() {
                                                sortjobs($(this).val());
                                            });
                                            
                                            function sortjobs(new_sortfield) {
                                                var current_job_url = '{{ request_fullpath | escape_javascript | replace: '%2C',',' }}';
                                                {% capture params_sortby_escaped %}{{ params['sort_by'] | escape_javascript }}{% endcapture %}
                                                var params_sortby_escaped = '{{ params_sortby_escaped }}';
                                                var current_sortfield = '';
                                                var current_sortorder = '';
                                                var new_sortorder = '';
                                                var new_job_url = '';

                                                {% if params['sort_by'] != blank %}
                                                    {% assign sortbyfield = params_sortby_escaped | split: ',' | assign_to: 'sortby_params' %}
                                                    current_sortfield = '{{ sortby_params[0] }}';
                                                    current_sortorder = '{{ sortby_params[1] }}';
                                                {% endif %}

                                                if (new_sortfield == 'default') {
                                                    new_sortorder = '';
                                                }
                                                else if (new_sortfield == current_sortfield) {
                                                    if (current_sortorder == 'asc') {
                                                        new_sortorder = ',desc';
                                                    }
                                                    else {
                                                        new_sortorder = ',asc';
                                                    }
                                                }
                                                else {
                                                    new_sortorder = ',asc'; 
                                                }

                                                {% if params['sort_by'] != blank %}
                                                    new_job_url = current_job_url.replace('{{ params_sortby_escaped }}',new_sortfield+new_sortorder);
                                                {% elsif request_fullpath contains '?' %}
                                                    new_job_url = current_job_url+'&sort_by='+new_sortfield+new_sortorder;
                                                {% else %}
                                                    new_job_url = current_job_url+'/?sort_by='+new_sortfield+new_sortorder;
                                                {% endif %}
                                                ds_tm_get_jobs_ajax(new_job_url);
                                            }
                                        </script>
                                        {% for job in jobs %}
                                            <div class="jobs-section__item padded-v-small">
                                                <div class="row">
                                                    <div class="columns {% if is_referral_site == 'true' %}large-4{% else %}large-6{% endif %}">
                                                        {% assign date_job = job.updated_at | date: '%s' %}
                                                        {% assign date_current = 'now' | date: '%s' %}
                                                        {% assign diff_seconds = date_current | minus: date_job %}
                                                        {% assign diff_days = diff_seconds | divided_by: 3600.0 | divided_by: 24.0 %}
                                                        <h4 class="heading-5 space-none">
                                                            {{ job | link_to_job }}
                                                            {% if diff_days < 13.5 %}<sup class="text-small">NEW</sup>{% endif %}
                                                        </h4>
                                                    </div>
                                                    <div class="columns large-3">
                                                        <span class="hide">Location: </span>
                                                        {% if job.location.city != blank %}
                                                            {{ job.location.city }}{% if job.location.state_prov_short != blank %},{% endif %}
                                                        {% endif %}
                                                        {% if job.location.state_prov_short != blank %}
                                                            {% capture job_location_state_prov_short_no_digit %}{{ job.location.state_prov_short | replace_global_regex: "[\d]", ":::" }}{% endcapture %}
                                                            {% if job_location_state_prov_short_no_digit contains ':::' %}
                                                                {{ job.location.state_prov }}
                                                            {% else %}
                                                                {{ job.location.state_prov_short }}
                                                            {% endif %}
                                                        {% endif %}
                                                    </div>
                                                    <div class="columns large-3"><span class="hide-for-large">Category: </span>{{ job.cfm4 }}</div>
                                                    {% if is_referral_site == 'true' %}
                                                        <div class="columns large-2">
                                                            <span class="hide-for-large">Incentive:</span>
                                                            {% if job.referral_incentive_amount != blank %}
                                                                {% if job.referral_incentive_currency == 'USD' or job.referral_incentive_currency == 'CAD' %}${% elsif job.referral_incentive_currency == 'EUR' %}€{% elsif job.referral_incentive_currency == 'GBP' %}£{% endif %}{{ job.referral_incentive_amount }} ({{ job.referral_incentive_currency }})
                                                            {% elsif job.referral_incentive_description != blank  %}    
                                                                {{ job.referral_incentive_description }}
                                                            {% else %}
                                                                None
                                                            {% endif %}
                                                            &nbsp;
                                                        </div>
                                                    {% endif %}
                                                </div>
                                            </div>  
                                        {% endfor %}
                                    </div><!--close .jobs-section__list-->
                                    <div class="jobs-section__paginate">
                                        <a href="{{ request_fullpath }}{% if request_fullpath contains '?' %}&{% else %}?{% endif %}page=2" class="jobs-section__paginate-view-more" rel="nofollow">View more jobs</a>
                                        {{ jobs | paginate }}
                                    </div>
                                {% endif %}
                            </div><!--close .jobs-section__inner-->
                        </div><!--close .jobs-section-->
                    </section>
                </div>
            </div><!--close .row-->

        </div><!--close .padded-v-xlarge-->
    </div><!--close .page-details-wrapper-->
 
{% endif %}{% comment %}END if params['ns_similar_jobs'] == 1{% endcomment %}
 
{% page_required_footer %}